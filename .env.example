# Copy this file to `.env` and fill in your key.
# Get a free Gemini API key at https://aistudio.google.com/apikey

GEMINI_API_KEY=your-key-here

# Optional: override the default model (gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- Google Calendar OAuth (optional; the app works without it) ---
# 1. https://console.cloud.google.com -> create a project
# 2. "APIs & Services" -> enable the "Google Calendar API"
# 3. OAuth consent screen -> External -> add your own Gmail as a test user
# 4. Credentials -> Create OAuth client ID -> Web application
#    Authorized redirect URI:  http://localhost:5000/oauth2callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Signs the Flask session cookie (carries the OAuth state/PKCE verifier).
# Any long random string works, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

